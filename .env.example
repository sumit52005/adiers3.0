# ─── Supabase ────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Cloud Vision API ─────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Cloud Vision API" first. Without this key, media validation
# will mark all uploads as "unverified" (graceful fallback — won't block reports).
REACT_APP_VISION_API_KEY=YOUR_VISION_API_KEY
